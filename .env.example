# ============================================================================
# Priv-Eye environment configuration
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================================

# --- App ---------------------------------------------------------------------
ENVIRONMENT=development            # development | staging | production
DEBUG=true                         # MUST be false in prod (see ASVS V7.4)
LOG_LEVEL=INFO

# --- Auth --------------------------------------------------------------------
# 32+ bytes, high entropy. Rotate by reissuing all tokens.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_openssl_rand_64
JWT_ALGORITHM=HS256                # Switch to RS256 in prod (see docs/DEPLOYMENT.md)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Argon2id parameters (OWASP recommended 2023+)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- Database ----------------------------------------------------------------
# Default SQLite for local; use Postgres in prod.
# Example prod: postgresql+asyncpg://priveye:<pw>@db:5432/priveye
DATABASE_URL=sqlite+aiosqlite:///./priveye.db

# --- Agent / HMAC ------------------------------------------------------------
AGENT_REPLAY_WINDOW_SECONDS=300    # ±5 minutes for timestamp tolerance
AGENT_NONCE_TTL_SECONDS=600        # Nonce cache TTL

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_API_PER_MIN=300
RATE_LIMIT_SCAN_PER_HOST_PER_MIN=60

# --- ML model ----------------------------------------------------------------
MODEL_PATH=./priveye_api/ml/model.pkl
# Expected SHA256 of the model file. Computed by scripts/train_model.py.
# Leave empty to skip check (dev only — warn logged).
MODEL_SHA256=

# --- Gemini (optional) -------------------------------------------------------
# Leave unset to disable /api/v1/insights entirely.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_PER_USER_DAILY_QUOTA=30

# --- CORS --------------------------------------------------------------------
# Comma-separated. No wildcards in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
